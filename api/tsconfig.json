{
	"compilerOptions": {
		"target": "ES2020", // Use modern JS features
		"module": "nodenext", // Node.js module system
		"rootDir": "src", // Your source folder
		"outDir": "dist", // Compiled JS output folder
		"strict": true, // Enable all strict checks
		"esModuleInterop": true, // Allow default imports from CommonJS
		"forceConsistentCasingInFileNames": true, // Prevent case mismatches
		"skipLibCheck": true, // Skip type checks for dependencies
		"moduleResolution": "nodenext", // Resolve modules like Node.js
		"resolveJsonModule": true, // Allow importing JSON files
		"allowJs": true, // Allow JS files if needed
		"noImplicitAny": true, // Prevent implicit any types
		"strictNullChecks": true, // Ensure null/undefined safety
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"lib": ["ES2020", "ESNext"], // Include all JS built-ins
		"types": ["node"], // Include Node.js types
		"paths": {
			"@src/*": ["./src/*"]
		}
	},
	"include": ["src"], // Include all source files
	"exclude": ["node_modules", "dist"]
}
