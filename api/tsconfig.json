{
	"compilerOptions": {
		"target": "ES2020", // Modern JavaScript
		"module": "nodenext", // Node.js ESM support
		"moduleResolution": "nodenext", // Correct resolution for ESM
		"rootDir": "src", // Source folder
		"outDir": "dist", // Compiled JS output
		"strict": true, // Enable all strict type checks
		"esModuleInterop": true, // Allow default imports from CommonJS
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true, // Allow importing JSON
		"allowJs": true, // Allow JS files if needed
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"lib": ["ES2020", "ESNext"], // Include modern JS built-ins
		"types": ["node"], // Node.js types
		"paths": {
			"@src/*": ["./src/*"]
		}
	},
	"include": ["src"], // Include source files
	"exclude": ["node_modules", "dist"] // Exclude compiled files
}
