{
	"expo": {
		"name": "AgriNova",
		"slug": "pest-app",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./src/assets/icon.png",
		"scheme": "pestapp",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.capstone.agrinova"
		},
		"android": {
			"package": "com.capstone.agrinova",
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./src/assets/icon.png",
				"backgroundImage": "./src/assets/icon.png",
				"monochromeImage": "./src/assets/icon.png"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"permissions": [
				"android.permission.CAMERA",
				"android.permission.RECORD_AUDIO"
			]
		},
		"web": {
			"output": "static",
			"favicon": "./src/assets/icon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./src/assets/icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"expo-secure-store",
			[
				"expo-camera",
				{
					"cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
					"microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
					"recordAudioAndroid": false
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "Allow AgriNova to access your photos to upload plant images for analysis."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "f8fd8708-b254-47b0-9623-ebdb03976476"
			}
		}
	}
}
